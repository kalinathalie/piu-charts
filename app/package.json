{
  "name": "piu-charts-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:web": "expo export -p web",
    "deploy:piucharts": "npm run export:web && node -e \"require('fs').writeFileSync('dist/.nojekyll','')\" && npx gh-pages -d dist -b main -t --repo https://github.com/piucharts/piucharts.github.io.git"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@types/react": "~19.2.14",
    "expo": "^56.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2",
    "typescript": "~6.0.3"
  }
}
